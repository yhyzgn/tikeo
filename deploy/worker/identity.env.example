# Stable Worker identity template. Source this file from systemd, Compose, shell,
# or map the same names into SDK-specific config.

# Server endpoint. Workers initiate outbound gRPC; no business inbound port is required.
TIKEO_WORKER_ENDPOINT=http://127.0.0.1:9998

# Scope and placement reported during RegisterWorker.
TIKEO_WORKER_NAMESPACE=default
TIKEO_WORKER_APP=default
TIKEO_WORKER_CLUSTER=local
TIKEO_WORKER_REGION=local
TIKEO_WORKER_POOL=default

# Stable host identity for VM/bare metal/systemd. Prefer explicit inventory/cloud id,
# then /etc/machine-id, then stable hostname. Do not use the server-assigned worker_id.
TIKEO_WORKER_HOST_ID=dev-host
TIKEO_WORKER_SERVICE_NAME=tikeo-worker
TIKEO_WORKER_INSTANCE_SLOT=slot-1

# Recommended logical instance key for VM/bare metal/systemd workers.
# Most env-file parsers do not expand nested variables, so keep a concrete value here.
TIKEO_WORKER_INSTANCE_ID=tikeo-worker@dev-host#slot-1

# Comma-separated hints for simple shell wrappers; SDKs may expose native lists/maps.
TIKEO_WORKER_CAPABILITIES=rust,demo
TIKEO_WORKER_LABELS=worker_pool=default,runtime=rust
