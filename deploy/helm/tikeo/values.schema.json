{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://tikeo.yhyzgn.com/helm/values.schema.json",
  "title": "Tikeo Helm values",
  "description": "values.schema.json",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "namespaceOverride": {
      "type": "string"
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "interval": {
          "type": "string"
        },
        "scrapeTimeout": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "gatewayApi": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "server": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "httpPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "workerTunnelPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "storage": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "sqlite",
                "external"
              ]
            },
            "existingSecret": {
              "type": "string"
            },
            "persistence": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "size": {
                  "type": "string",
                  "minLength": 1
                },
                "accessModes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "sqlite",
                "postgres",
                "mysql",
                "cockroachdb"
              ]
            },
            "timestampOffset": {
              "type": "string"
            },
            "sqlite": {
              "type": "object",
              "additionalProperties": true
            },
            "external": {
              "type": "object",
              "additionalProperties": true
            },
            "secretKeys": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "required": [
            "mode"
          ]
        },
        "cluster": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "standalone",
                "raft"
              ]
            },
            "peerServiceName": {
              "type": "string"
            },
            "peerPort": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "transportTokenExistingSecret": {
              "type": "string"
            },
            "transportTokenSecretKey": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "mode",
            "peerPort",
            "transportTokenSecretKey"
          ]
        }
      }
    },
    "web": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  }
}
