# Copy to .env and adjust before running docker compose.
# Compose files use Docker Hub release images by default. For production rollback safety,
# pin these to yhyzgn/tikeo-server:v${TIKEO_VERSION} and yhyzgn/tikeo-web:v${TIKEO_VERSION}.
TIKEO_IMAGE=yhyzgn/tikeo-server:latest
TIKEO_WEB_IMAGE=yhyzgn/tikeo-web:latest

# Host ports.
TIKEO_HTTP_PORT=9090
TIKEO_WORKER_TUNNEL_PORT=9998
TIKEO_WEB_PORT=8080
TIKEO_PROMETHEUS_PORT=9091
TIKEO_POSTGRES_PORT=15432
TIKEO_MYSQL_PORT=13306

# Persistent named volumes used by docker-compose*.yml.
# SQLite stack: Server persists /data/tikeo.db into TIKEO_DATA_VOLUME.
# All stacks: Server writes optional file logs to /logs/tikeo.log in TIKEO_LOGS_VOLUME.
# PostgreSQL/MySQL stacks: database state lives in the database service volume, not Server /data.
TIKEO_DATA_VOLUME=tikeo-data
TIKEO_LOGS_VOLUME=tikeo-logs
TIKEO_POSTGRES_DATA_VOLUME=tikeo-postgres-data
TIKEO_MYSQL_DATA_VOLUME=tikeo-mysql-data

# Worker-side helper for local smoke/demo commands. This is not consumed by the Server container.
# Server public notification links are configured in config/tikeo.toml via notification_delivery.public_console_base_url.
TIKEO_WORKER_TUNNEL_PUBLIC_ENDPOINT=http://127.0.0.1:9998

# Service behavior defaults live in ./config/tikeo.toml, not in this .env file:
# - server listen addresses
# - storage.database.*
# - notification_delivery.public_console_base_url
# - auth.local_login_enabled
# - observability.logging.level and log_dir=/logs
# - alert_retry and notification_delivery retry policy
# Edit the mounted TOML file directly when these values need to change.

# PostgreSQL container defaults. Change these before shared deployment, then keep
# config/tikeo.toml storage.database.* in sync with the same credentials.
TIKEO_POSTGRES_DB=tikeo
TIKEO_POSTGRES_USER=tikeo
TIKEO_POSTGRES_PASSWORD=change-me

# MySQL container defaults. Change these before shared deployment, then keep
# config/tikeo.toml storage.database.* in sync with the same credentials.
TIKEO_MYSQL_DATABASE=tikeo
TIKEO_MYSQL_USER=tikeo
TIKEO_MYSQL_PASSWORD=change-me
TIKEO_MYSQL_ROOT_PASSWORD=change-root

# Mimalloc policy: promptly purge and decommit freed pages back to the OS.
MIMALLOC_PURGE_DELAY=0
MIMALLOC_PURGE_DECOMMITS=1
MIMALLOC_ABANDONED_PAGE_PURGE=1

# Worker identity defaults for local smoke/demo workers.
TIKEO_WORKER_NAMESPACE=default
TIKEO_WORKER_APP=default
TIKEO_WORKER_CLUSTER=compose
TIKEO_WORKER_REGION=local
TIKEO_WORKER_POOL=default
TIKEO_WORKER_HOST_ID=compose-host
TIKEO_WORKER_SERVICE_NAME=demo-worker
TIKEO_WORKER_INSTANCE_SLOT=slot-1
TIKEO_WORKER_INSTANCE_ID=demo-worker@compose-host#slot-1
TIKEO_WORKER_CAPABILITIES=rust,demo
TIKEO_WORKER_LABELS=worker_pool=default,runtime=rust,deployment=compose

# Alert provider secret refs use env:NAME indirection in rule/channel JSON.
# alert_secrets.allow_env_refs and env_prefix defaults live in ./config/tikeo.toml.
# Example: {"type":"email","to":["ops@example.com"],"smtp_url_secret_ref":"env:TIKEO_ALERT_SECRET_SMTP_URL","username":"apikey","password_secret_ref":"env:TIKEO_ALERT_SECRET_SMTP_PASSWORD"}
# TIKEO_ALERT_SECRET_SMTP_URL=smtps://smtp.example.com:465
# TIKEO_ALERT_SECRET_SMTP_PASSWORD=change-me
