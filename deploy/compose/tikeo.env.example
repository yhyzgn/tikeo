# Copy to .env and adjust before running docker compose.
TIKEO_IMAGE=yhyzgn/tikeo-server:dev
TIKEO_WEB_IMAGE=yhyzgn/tikeo-web:dev
TIKEO_HTTP_PORT=9090
TIKEO_WORKER_TUNNEL_PORT=9998
TIKEO_WEB_PORT=8080
TIKEO_PROMETHEUS_PORT=9091
TIKEO_DATA_VOLUME=tikeo-data

# Mimalloc policy: promptly purge and decommit freed pages back to the OS.
MIMALLOC_PURGE_DELAY=0
MIMALLOC_PURGE_DECOMMITS=1
MIMALLOC_ABANDONED_PAGE_PURGE=1

# Public endpoint workers use for outbound gRPC. This is intentionally separate
# from the container listen address and should be reachable from worker hosts.
TIKEO_WORKER_TUNNEL_PUBLIC_ENDPOINT=http://127.0.0.1:9998

# Override storage for external DB if needed:
# TIKEO__STORAGE__DATABASE_URL=postgres://tikeo:change-me@postgres:5432/tikeo

# Worker identity defaults for local smoke/demo workers.
TIKEO_WORKER_NAMESPACE=default
TIKEO_WORKER_APP=default
TIKEO_WORKER_CLUSTER=compose
TIKEO_WORKER_REGION=local
TIKEO_WORKER_POOL=default
TIKEO_WORKER_HOST_ID=compose-host
TIKEO_WORKER_SERVICE_NAME=demo-worker
TIKEO_WORKER_INSTANCE_SLOT=slot-1
TIKEO_WORKER_INSTANCE_ID=demo-worker@compose-host#slot-1
TIKEO_WORKER_CAPABILITIES=rust,demo
TIKEO_WORKER_LABELS=worker_pool=default,runtime=rust,deployment=compose

# Alert provider secret refs use env:NAME indirection in rule channel JSON.
# Example: {"type":"email","to":["ops@example.com"],"smtp_url_secret_ref":"env:TIKEO_ALERT_SECRET_SMTP_URL","username":"apikey","password_secret_ref":"env:TIKEO_ALERT_SECRET_SMTP_PASSWORD"}
TIKEO__ALERT_SECRETS__ALLOW_ENV_REFS=true
TIKEO__ALERT_SECRETS__ENV_PREFIX=TIKEO_ALERT_SECRET_
# TIKEO_ALERT_SECRET_SMTP_URL=smtps://smtp.example.com:465
# TIKEO_ALERT_SECRET_SMTP_PASSWORD=change-me
