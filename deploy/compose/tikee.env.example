# Copy to .env and adjust before running docker compose.
TIKEE_IMAGE=tikee:dev
TIKEE_WEB_IMAGE=tikee-web:dev
TIKEE_HTTP_PORT=9090
TIKEE_WORKER_TUNNEL_PORT=9998
TIKEE_WEB_PORT=8080
TIKEE_PROMETHEUS_PORT=9091
TIKEE_DATA_VOLUME=tikee-data

# Public endpoint workers use for outbound gRPC. This is intentionally separate
# from the container listen address and should be reachable from worker hosts.
TIKEE_WORKER_TUNNEL_PUBLIC_ENDPOINT=http://127.0.0.1:9998

# Override storage for external DB if needed:
# TIKEE__STORAGE__DATABASE_URL=postgres://tikee:change-me@postgres:5432/tikee

# Worker identity defaults for local smoke/demo workers.
TIKEE_WORKER_NAMESPACE=default
TIKEE_WORKER_APP=default
TIKEE_WORKER_CLUSTER=compose
TIKEE_WORKER_REGION=local
TIKEE_WORKER_POOL=default
TIKEE_WORKER_HOST_ID=compose-host
TIKEE_WORKER_SERVICE_NAME=demo-worker
TIKEE_WORKER_INSTANCE_SLOT=slot-1
TIKEE_WORKER_INSTANCE_ID=demo-worker@compose-host#slot-1
TIKEE_WORKER_CAPABILITIES=rust,demo
TIKEE_WORKER_LABELS=worker_pool=default,runtime=rust,deployment=compose

# Alert provider secret refs use env:NAME indirection in rule channel JSON.
# Example: {"type":"email","to":["ops@example.com"],"smtp_url_secret_ref":"env:TIKEE_ALERT_SECRET_SMTP_URL","username":"apikey","password_secret_ref":"env:TIKEE_ALERT_SECRET_SMTP_PASSWORD"}
TIKEE__ALERT_SECRETS__ALLOW_ENV_REFS=true
TIKEE__ALERT_SECRETS__ENV_PREFIX=TIKEE_ALERT_SECRET_
# TIKEE_ALERT_SECRET_SMTP_URL=smtps://smtp.example.com:465
# TIKEE_ALERT_SECRET_SMTP_PASSWORD=change-me
