# /etc/tikeo/tikeo.env
TIKEO_CONFIG=/etc/tikeo/tikeo.toml
RUST_LOG=info,tikeo=info

# Mimalloc policy: promptly purge and decommit freed pages back to the OS.
MIMALLOC_PURGE_DELAY=0
MIMALLOC_PURGE_DECOMMITS=1
MIMALLOC_ABANDONED_PAGE_PURGE=1
# Prefer an external DB in production:
# TIKEO__STORAGE__DATABASE_URL=postgres://tikeo:change-me@db.example:5432/tikeo

# Public endpoint used by external workers. The server still listens according
# to /etc/tikeo/tikeo.toml; this value is for operator docs/scripts.
TIKEO_WORKER_TUNNEL_PUBLIC_ENDPOINT=http://127.0.0.1:9998

# Alert provider secret refs use env:NAME indirection in rule channel JSON.
TIKEO__ALERT_SECRETS__ALLOW_ENV_REFS=true
TIKEO__ALERT_SECRETS__ENV_PREFIX=TIKEO_ALERT_SECRET_
# TIKEO_ALERT_SECRET_SMTP_URL=smtps://smtp.example.com:465
# TIKEO_ALERT_SECRET_SMTP_PASSWORD=change-me
