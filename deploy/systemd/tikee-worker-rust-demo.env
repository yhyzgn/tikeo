# /etc/tikee/tikee-worker-rust-demo.env
TIKEE_WORKER_ENDPOINT=http://127.0.0.1:9998
TIKEE_WORKER_NAMESPACE=default
TIKEE_WORKER_APP=default
TIKEE_WORKER_CLUSTER=bare-metal
TIKEE_WORKER_REGION=local
TIKEE_WORKER_POOL=default
TIKEE_WORKER_SERVICE_NAME=rust-demo-worker
TIKEE_WORKER_CAPABILITIES=rust,demo
TIKEE_WORKER_LABELS=worker_pool=default,runtime=rust,deployment=systemd
