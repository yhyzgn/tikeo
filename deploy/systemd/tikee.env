# /etc/tikee/tikee.env
TIKEE_CONFIG=/etc/tikee/tikee.toml
RUST_LOG=info,tikee=info

# Mimalloc policy: promptly purge and decommit freed pages back to the OS.
MIMALLOC_PURGE_DELAY=0
MIMALLOC_PURGE_DECOMMITS=1
MIMALLOC_ABANDONED_PAGE_PURGE=1
# Prefer an external DB in production:
# TIKEE__STORAGE__DATABASE_URL=postgres://tikee:change-me@db.example:5432/tikee

# Public endpoint used by external workers. The server still listens according
# to /etc/tikee/tikee.toml; this value is for operator docs/scripts.
TIKEE_WORKER_TUNNEL_PUBLIC_ENDPOINT=http://127.0.0.1:9998

# Alert provider secret refs use env:NAME indirection in rule channel JSON.
TIKEE__ALERT_SECRETS__ALLOW_ENV_REFS=true
TIKEE__ALERT_SECRETS__ENV_PREFIX=TIKEE_ALERT_SECRET_
# TIKEE_ALERT_SECRET_SMTP_URL=smtps://smtp.example.com:465
# TIKEE_ALERT_SECRET_SMTP_PASSWORD=change-me
