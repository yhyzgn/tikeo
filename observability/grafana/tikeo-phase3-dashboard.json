{
  "uid": "tikeo-phase3-ops",
  "title": "tikeo Phase 3 Operations",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "tikeo",
    "phase3",
    "operations"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "HTTP Request Rate",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "tikeo:http_requests:rate5m"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP p95 Latency",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "tikeo:http_latency:p95_5m"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Connected Workers",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(tikeo_worker_connected_total)"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Worker Dispatch Outcomes",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(tikeo_worker_dispatch_total[5m])) by (result)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP Error Ratio",
      "description": "HTTP availability SLO derived from request counters.",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "tikeo:http_errors:ratio5m"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Dispatch Queue Pending Age p95",
      "description": "Dispatch queue wait-time SLO backed by server-emitted histogram buckets.",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "tikeo:dispatch_pending_age:p95_5m"
        },
        {
          "refId": "B",
          "expr": "tikeo:dispatch_latency:p95_5m"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 16
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Workflow SLA Durations",
      "description": "Workflow and map shard SLA histograms emitted by metrics summary snapshots.",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "tikeo:workflow_instance_duration:p95_5m"
        },
        {
          "refId": "B",
          "expr": "tikeo:workflow_shard_duration:p95_5m"
        },
        {
          "refId": "C",
          "expr": "tikeo:workflow_instance_success:ratio"
        },
        {
          "refId": "D",
          "expr": "tikeo:workflow_shard_success:ratio"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 16,
        "x": 8,
        "y": 16
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Raft Shard Owners / Skew",
      "description": "Active scheduler owner count and skew. Skew should normally be 0 or 1.",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "C",
          "expr": "sum(tikeo_cluster_can_schedule)"
        },
        {
          "refId": "A",
          "expr": "tikeo_cluster_shard_ownership_owner_count"
        },
        {
          "refId": "B",
          "expr": "tikeo_cluster_shard_ownership_skew"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 22
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Dispatch Queue Pending By Owner",
      "description": "Per-owner pending queue depth for locating unhealthy shard owners.",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (owner_node_id) (tikeo_dispatch_queue_pending_by_owner)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 22
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Oldest Pending Age By Owner / Outbox",
      "description": "Per-owner queue age and durable outbox age for Worker Tunnel gateway diagnosis.",
      "datasource": "${datasource}",
      "targets": [
        {
          "refId": "A",
          "expr": "max by (owner_node_id) (tikeo_dispatch_queue_oldest_pending_age_by_owner_seconds)"
        },
        {
          "refId": "B",
          "expr": "tikeo_worker_dispatch_outbox_oldest_queued_age_seconds"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 22
      }
    }
  ]
}
